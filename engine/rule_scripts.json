{
  "events": {
    "landing.f.resolve": [
      {
        "name": "default_f1",
        "when": {"cell": "F1"},
        "actions": [
          {"type": "track_strategy_stat", "stat": "f1_visits", "delta": 1},
          {"type": "change_f", "amount": "$state.config.board.f1_increment"},
          {"type": "change_shards", "target": "player", "amount": "$state.config.board.f1_shards"},
          {"type": "track_strategy_stat", "stat": "shards_gained_f", "delta": "$state.config.board.f1_shards"},
          {"type": "set_result", "value": {"type": "F1", "f_delta": "$state.config.board.f1_increment", "shards": "$state.config.board.f1_shards"}},
          {"type": "apply_same_tile_bonus"}
        ],
        "return": "result"
      },
      {
        "name": "default_f2",
        "when": {"cell": "F2"},
        "actions": [
          {"type": "track_strategy_stat", "stat": "f2_visits", "delta": 1},
          {"type": "change_f", "amount": "$state.config.board.f2_increment"},
          {"type": "change_shards", "target": "player", "amount": "$state.config.board.f2_shards"},
          {"type": "track_strategy_stat", "stat": "shards_gained_f", "delta": "$state.config.board.f2_shards"},
          {"type": "set_result", "value": {"type": "F2", "f_delta": "$state.config.board.f2_increment", "shards": "$state.config.board.f2_shards"}},
          {"type": "apply_same_tile_bonus"}
        ],
        "return": "result"
      }
    ],
    "fortune.cleanup.resolve": [
      {
        "name": "default_cleanup",
        "actions": [
          {"type": "cleanup_burdens", "multiplier": "$multiplier", "payout": "$payout", "name": "$name"}
        ],
        "return": "result"
      }
    ],
    "game.end.evaluate": [
      {
        "name": "default_end_evaluation",
        "actions": [
          {"type": "evaluate_end_rules"}
        ],
        "return": "bool_true"
      }
    ]
  }
}
