MRN_DEPLOYMENT_NAME=project-mrn-runtime
MRN_SERVER_IMAGE=project-mrn-server:runtime
MRN_REDIS_IMAGE=redis:7-alpine
MRN_REDIS_URL=redis://redis:6379/0
MRN_REDIS_KEY_PREFIX=mrn:{project-mrn-prod}
MRN_SERVER_PORT=9090
MRN_RESTART_RECOVERY_POLICY=keep
MRN_GAME_LOG_ARCHIVE_PATH=/app/data/game_logs
MRN_LOG_LEVEL=INFO
MRN_DEBUG_GAME_LOGS=0
