  "automation_commands": [
    "npm run e2e:module-runtime"
  ],
  "required_wire_fields": [
    "request_id",
    "request_type",
    "player_id",
    "frame_id",
    "module_id",
    "module_type",
    "module_cursor"
  ],
  "simultaneous_wire_fields": [
    "batch_id",
    "missing_player_ids",
    "resume_tokens_by_player_id"
