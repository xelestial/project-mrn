{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "runtime-contracts/ws/inbound.decision_ack.schema.json",
  "title": "InboundDecisionAckMessage",
  "type": "object",
  "required": [
    "type",
    "seq",
    "session_id",
    "payload"
  ],
  "properties": {
    "type": {
      "const": "decision_ack"
    },
    "seq": {
      "type": "integer",
      "minimum": 0
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "server_time_ms": {
      "type": "integer",
      "minimum": 0
    },
    "payload": {
      "type": "object",
      "required": [
        "request_id",
        "status"
      ],
      "anyOf": [
        {
          "required": ["player_id"]
        },
        {
          "required": ["primary_player_id", "primary_player_id_source"]
        },
        {
          "required": ["public_player_id"]
        },
        {
          "required": ["seat_id"]
        },
        {
          "required": ["viewer_id"]
        }
      ],
      "allOf": [
        {
          "if": {
            "required": ["player_id"],
            "properties": {
              "player_id": {
                "type": "integer"
              }
            }
          },
          "then": {
            "required": [
              "player_id_alias_role",
              "primary_player_id",
              "primary_player_id_source",
              "legacy_player_id"
            ]
          }
        },
        {
          "if": {
            "required": ["primary_player_id", "primary_player_id_source"],
            "properties": {
              "primary_player_id_source": {
                "enum": ["public", "protocol"]
              }
            }
          },
          "then": {
            "properties": {
              "primary_player_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        {
          "if": {
            "required": ["primary_player_id", "primary_player_id_source"],
            "properties": {
              "primary_player_id_source": {
                "const": "legacy"
              }
            }
          },
          "then": {
            "properties": {
              "primary_player_id": {
                "type": "integer",
                "minimum": 1
              }
            }
          }
        }
      ],
      "properties": {
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "accepted",
            "rejected",
            "stale"
          ]
        },
        "player_id": {
          "type": ["integer", "string"],
          "minimum": 1,
          "minLength": 1
        },
        "player_id_alias_role": {
          "type": "string",
          "enum": ["legacy_compatibility_alias"]
        },
        "primary_player_id": {
          "type": ["integer", "string"],
          "minimum": 1,
          "minLength": 1
        },
        "primary_player_id_source": {
          "type": "string",
          "enum": ["public", "protocol", "legacy"]
        },
        "legacy_player_id": {
          "type": "integer",
          "minimum": 1
        },
        "public_player_id": {
          "type": "string",
          "minLength": 1
        },
        "seat_id": {
          "type": "string",
          "minLength": 1
        },
        "viewer_id": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
