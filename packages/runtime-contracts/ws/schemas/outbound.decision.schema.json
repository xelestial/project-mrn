{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "runtime-contracts/ws/outbound.decision.schema.json",
  "title": "OutboundDecisionMessage",
  "type": "object",
  "required": [
    "type",
    "request_id",
    "player_id",
    "choice_id",
    "client_seq"
  ],
  "allOf": [
    {
      "if": {
        "required": ["player_id"],
        "properties": {
          "player_id": {
            "type": "integer"
          }
        }
      },
      "then": {
        "required": [
          "player_id_alias_role",
          "primary_player_id",
          "primary_player_id_source",
          "legacy_player_id"
        ]
      }
    }
  ],
  "properties": {
    "type": {
      "const": "decision"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "player_id": {
      "type": ["integer", "string"],
      "minimum": 1,
      "minLength": 1
    },
    "player_id_alias_role": {
      "type": "string",
      "enum": ["legacy_compatibility_alias"]
    },
    "primary_player_id": {
      "type": ["integer", "string"],
      "minimum": 1,
      "minLength": 1
    },
    "primary_player_id_source": {
      "type": "string",
      "enum": ["public", "protocol", "legacy"]
    },
    "legacy_player_id": {
      "type": "integer",
      "minimum": 1
    },
    "public_player_id": {
      "type": "string",
      "minLength": 1
    },
    "seat_id": {
      "type": "string",
      "minLength": 1
    },
    "viewer_id": {
      "type": "string",
      "minLength": 1
    },
    "choice_id": {
      "type": "string",
      "minLength": 1
    },
    "client_seq": {
      "type": "integer",
      "minimum": 0
    },
    "choice_payload": {
      "type": "object",
      "additionalProperties": true
    },
    "prompt_instance_id": {
      "type": "integer",
      "minimum": 0
    },
    "public_prompt_instance_id": {
      "type": "string",
      "minLength": 1
    },
    "prompt_fingerprint": {
      "type": "string",
      "minLength": 1
    },
    "prompt_fingerprint_version": {
      "type": "string",
      "minLength": 1
    },
    "resume_token": {
      "type": "string",
      "minLength": 1
    },
    "frame_id": {
      "type": "string",
      "minLength": 1
    },
    "module_id": {
      "type": "string",
      "minLength": 1
    },
    "module_type": {
      "type": "string",
      "minLength": 1
    },
    "module_cursor": {
      "type": "string",
      "minLength": 1
    },
    "batch_id": {
      "type": "string",
      "minLength": 1
    },
    "missing_player_ids": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 0
      }
    },
    "resume_tokens_by_player_id": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "missing_public_player_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "resume_tokens_by_public_player_id": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "missing_seat_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "resume_tokens_by_seat_id": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "missing_viewer_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "resume_tokens_by_viewer_id": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "view_commit_seq_seen": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": true
}
