{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "runtime-contracts/ws/outbound.decision.schema.json",
  "title": "OutboundDecisionMessage",
  "type": "object",
  "required": [
    "type",
    "request_id",
    "player_id",
    "choice_id",
    "client_seq"
  ],
  "allOf": [
    {
      "if": {
        "required": ["player_id"],
        "properties": {
          "player_id": {
            "type": "integer"
          }
        }
      },
      "then": {
        "required": [
          "player_id_alias_role",
          "primary_player_id",
          "primary_player_id_source"
        ]
      }
    }
  ],
  "properties": {
    "type": {
      "const": "decision"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "player_id": {
      "type": ["integer", "string"],
      "minimum": 1,
      "minLength": 1
    },
    "player_id_alias_role": {
      "type": "string",
      "enum": ["legacy_compatibility_alias"]
    },
    "primary_player_id": {
      "type": ["integer", "string"],
      "minimum": 1,
      "minLength": 1
    },
    "primary_player_id_source": {
      "type": "string",
      "enum": ["public", "protocol", "legacy"]
    },
    "legacy_player_id": {
      "type": "integer",
      "minimum": 1
    },
    "public_player_id": {
      "type": "string",
      "minLength": 1
    },
    "seat_id": {
      "type": "string",
      "minLength": 1
    },
    "viewer_id": {
      "type": "string",
      "minLength": 1
    },
    "choice_id": {
      "type": "string",
      "minLength": 1
    },
    "client_seq": {
      "type": "integer",
      "minimum": 0
    },
    "choice_payload": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
