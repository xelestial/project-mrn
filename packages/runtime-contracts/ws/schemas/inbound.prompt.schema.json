{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "runtime-contracts/ws/inbound.prompt.schema.json",
  "title": "InboundPromptMessage",
  "type": "object",
  "required": [
    "type",
    "seq",
    "session_id",
    "payload"
  ],
  "properties": {
    "type": {
      "const": "prompt"
    },
    "seq": {
      "type": "integer",
      "minimum": 0
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "server_time_ms": {
      "type": "integer",
      "minimum": 0
    },
    "payload": {
      "type": "object",
      "required": [
        "request_id",
        "request_type",
        "player_id",
        "timeout_ms",
        "legal_choices",
        "public_context"
      ],
      "allOf": [
        {
          "if": {
            "required": ["player_id"],
            "properties": {
              "player_id": {
                "type": "integer"
              }
            }
          },
          "then": {
            "required": [
              "player_id_alias_role",
              "primary_player_id",
              "primary_player_id_source",
              "legacy_player_id"
            ]
          }
        },
        {
          "if": {
            "required": ["primary_player_id", "primary_player_id_source"],
            "properties": {
              "primary_player_id_source": {
                "enum": ["public", "protocol"]
              }
            }
          },
          "then": {
            "properties": {
              "primary_player_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ],
      "properties": {
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "request_type": {
          "type": "string",
          "minLength": 1
        },
        "player_id": {
          "type": ["integer", "string"],
          "minimum": 1,
          "minLength": 1
        },
        "player_id_alias_role": {
          "type": "string",
          "enum": ["legacy_compatibility_alias"]
        },
        "primary_player_id": {
          "type": ["integer", "string"],
          "minimum": 1,
          "minLength": 1
        },
        "primary_player_id_source": {
          "type": "string",
          "enum": ["public", "protocol", "legacy"]
        },
        "legacy_player_id": {
          "type": "integer",
          "minimum": 1
        },
        "public_player_id": {
          "type": "string",
          "minLength": 1
        },
        "seat_id": {
          "type": "string",
          "minLength": 1
        },
        "viewer_id": {
          "type": "string",
          "minLength": 1
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 1
        },
        "fallback_policy": {
          "type": "string"
        },
        "legal_choices": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "choice_id"
            ],
            "properties": {
              "choice_id": {
                "type": "string",
                "minLength": 1
              },
              "title": {
                "type": "string"
              },
              "description": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "choices": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "choice_id"
            ],
            "properties": {
              "choice_id": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": true
          }
        },
        "public_context": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
