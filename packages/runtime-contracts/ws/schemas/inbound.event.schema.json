{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "runtime-contracts/ws/inbound.event.schema.json",
  "title": "InboundEventMessage",
  "type": "object",
  "required": [
    "type",
    "seq",
    "session_id",
    "payload"
  ],
  "properties": {
    "type": {
      "const": "event"
    },
    "seq": {
      "type": "integer",
      "minimum": 0
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "server_time_ms": {
      "type": "integer",
      "minimum": 0
    },
    "payload": {
      "type": "object",
      "required": [
        "event_type"
      ],
      "properties": {
        "event_type": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

