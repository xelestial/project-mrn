{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Selector Scene Fixture",
  "type": "object",
  "required": ["case_id", "metadata", "messages", "expected"],
  "properties": {
    "case_id": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "required": ["core_turn_resolution_order", "engine_advance_resolution_order"],
      "properties": {
        "core_turn_resolution_order": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "engine_advance_resolution_order": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      }
    },
    "messages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "seq", "session_id", "server_time_ms", "payload"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["event", "prompt", "decision_ack", "error", "heartbeat"]
          },
          "seq": { "type": "integer", "minimum": 1 },
          "session_id": { "type": "string", "minLength": 1 },
          "server_time_ms": { "type": "integer", "minimum": 0 },
          "payload": { "type": "object" }
        }
      }
    },
    "expected": {
      "type": "object",
      "required": ["scene"],
      "properties": {
        "scene": {
          "type": "object",
          "required": ["situation", "theater_feed", "core_action_feed", "timeline", "critical_alerts"],
          "properties": {
            "situation": { "type": "object" },
            "theater_feed": { "type": "array", "items": { "type": "object" } },
            "core_action_feed": { "type": "array", "items": { "type": "object" } },
            "timeline": { "type": "array", "items": { "type": "object" } },
            "critical_alerts": { "type": "array", "items": { "type": "object" } }
          }
        }
      }
    }
  }
}
