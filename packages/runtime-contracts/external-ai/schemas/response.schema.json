{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "runtime-contracts/external-ai/response.schema.json",
  "title": "ExternalAiDecisionResponse",
  "type": "object",
  "required": [
    "choice_id",
    "worker_contract_version",
    "capabilities"
  ],
  "properties": {
    "choice_id": { "type": "string", "minLength": 1 },
    "choice_payload": {
      "type": "object",
      "additionalProperties": true
    },
    "worker_id": { "type": "string" },
    "ready": { "type": "boolean" },
    "policy_mode": { "type": "string" },
    "policy_class": { "type": "string" },
    "worker_contract_version": { "type": "string", "minLength": 1 },
    "capabilities": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "supported_request_types": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "required_capabilities": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": true
}
